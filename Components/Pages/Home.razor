@page "/"
@using Services
@using Models
@inject DatabaseService DataService
@rendermode InteractiveServer

<PageTitle>Kelbin - Fullstack Developer Portfolio</PageTitle>

@if (isLoading)
{
    <div class="loading-container">
        <div class="loading-spinner">Loading...</div>
    </div>
}
else
{
    <div class="steam-header">
        <nav class="steam-nav">
            <a href="/">Profile</a>
            <a href="#achievements">Skills</a>
            <a href="#experience">Experience</a>
            <a href="#games">Projects</a>
        </nav>
    </div>

    <div class="steam-container">
        <!-- Profile Header -->
        @if (profileData != null)
        {
            <div class="profile-section">
                <div class="profile-header">
                    <div class="profile-avatar">
                        <img src="@profileData.AvatarUrl" alt="Profile Picture" class="avatar-image" />
                        <img src="@profileData.AvatarFrameUrl" alt="Profile Frame" class="avatar-frame" />
                    </div>
                    <div class="profile-info">
                        <h1 class="profile-name">@profileData.Name</h1>
                        <p class="profile-subtitle">@profileData.Title</p>
                        
                        <div class="about-summary">
                            <div class="player-bio-header">About</div>
                            <p>@profileData.Summary</p>
                        </div>

                        <div class="profile-stats">
                            @foreach (var stat in profileData.Stats)
                            {
                                <div class="stat-item">
                                    <div class="stat-value">@stat.Value</div>
                                    <div class="stat-label">@stat.Label</div>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(profileData.ResumeUrl))
                            {
                                <a href="@profileData.ResumeUrl" target="_blank" class="resume-button">
                                    <i class="bi-download"></i>
                                    <span>Download Resume</span>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Content Grid -->
        <div class="content-grid">
            <!-- Main Content -->
            <div>
                <!-- Skills Section -->
                @if (skillsData != null)
                {
                    <div class="content-box" id="achievements">
                        <div class="content-box-header">
                            <h2 class="content-box-title">Skills</h2>
                        </div>
                        <div class="achievements-section">
                            @foreach (var category in skillsData.Categories)
                            {
                                <div class="achievement-category">
                                    <h3 class="achievement-category-title">@category.Title</h3>
                                    <div class="achievements-list">
                                        @foreach (var skill in category.Skills)
                                        {
                                            <div class="achievement-badge unlocked">
                                                <div class="achievement-name">@skill</div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Career Quests Section -->
                @if (experienceData != null)
                {
                    <div class="content-box" id="experience" style="margin-top: 20px;">
                        <div class="content-box-header">
                            <h2 class="content-box-title">Experience</h2>
                        </div>
                        <div class="experience-list">
                            @for (int i = 0; i < experienceData.Experiences.Count; i++)
                            {
                                var exp = experienceData.Experiences[i];
                                var isCurrentJob = i == 0;
                                <div class="experience-item quest-item @(isCurrentJob ? "quest-in-progress" : "")">
                                    <div class="experience-header">
                                        <div class="experience-title-section">
                                            <h3 class="experience-position">@exp.Position</h3>
                                            <p class="experience-company">@exp.Company • @exp.Location</p>
                                        </div>
                                        <div class="experience-duration">@exp.Duration</div>
                                    </div>
                                    @if (isCurrentJob)
                                    {
                                        <div class="quest-status quest-in-progress-badge">Current</div>
                                    }
                                    else
                                    {
                                        <div class="quest-status">Completed</div>
                                    }
                                    <div class="quest-objectives">
                                        <ul class="experience-description">
                                            @foreach (var responsibility in exp.Responsibilities)
                                            {
                                                <li>@responsibility</li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Game Library -->
                @if (projectsData != null)
                {
                    <div class="content-box" id="games" style="margin-top: 20px;">
                        <div class="content-box-header">
                            <h2 class="content-box-title">Projects</h2>
                            <a href="https://github.com/kelbindev" target="_blank" class="view-all-link">View on GitHub →</a>
                        </div>
                        <div class="project-grid">
                            @foreach (var project in projectsData.Projects)
                            {
                                <div class="game-card">
                                    @if (!string.IsNullOrEmpty(project.Url))
                                    {
                                        <div class="game-status-badge">Live</div>
                                    }
                                    <div class="project-info">
                                        <div class="game-title">@project.Title</div>
                                        <div class="project-description">@project.Description</div>
                                        <div class="game-tech">
                                            @foreach (var tech in project.Technologies)
                                            {
                                                <span class="tech-tag">@tech</span>
                                            }
                                        </div>
                                        <div class="game-actions">
                                            @if (!string.IsNullOrEmpty(project.Url))
                                            {
                                                <a href="@project.Url" target="_blank" class="game-button play-button">
                                                    <i class="bi-play-circle-fill"></i>
                                                    <span>Live Demo</span>
                                                </a>
                                            }
                                            @if (!string.IsNullOrEmpty(project.GitHubUrl))
                                            {
                                                <a href="@project.GitHubUrl" target="_blank" class="game-button source-button">
                                                    <i class="bi-github"></i>
                                                    <span>View Source</span>
                                                </a>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Sidebar -->
            <div>
                @if (contactData != null)
                {
                    <!-- Education -->
                    <div class="content-box">
                        <div class="content-box-header">
                            <h2 class="content-box-title">Education</h2>
                        </div>
                        <div class="education-section">
                            <div class="education-item">
                                <h3 class="education-degree">@contactData.Education.Degree</h3>
                                <p class="education-school">@contactData.Education.School</p>
                                <p class="education-location">@contactData.Education.Location</p>
                            </div>
                        </div>
                    </div>

                    <!-- Location -->
                    <div class="content-box" style="margin-top: 20px;">
                        <div class="location-info">
                            <i class="bi-geo-alt-fill location-icon"></i>
                            <div class="location-text">
                                <strong>Currently Based in</strong><br />
                                @contactData.Location
                            </div>
                        </div>
                    </div>

                    <!-- Links Section -->
                    <div class="content-box" style="margin-top: 20px;">
                        <div class="content-box-header">
                            <h2 class="content-box-title">Connect</h2>
                        </div>
                        <div class="links-list">
                            @foreach (var link in contactData.Links)
                            {
                                <a href="@link.Url" class="link-item" target="_blank">
                                    <i class="@link.Icon link-icon"></i>
                                    <span class="link-text">@link.Text</span>
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private ProfileData? profileData;
    private SkillsData? skillsData;
    private ExperienceData? experienceData;
    private ProjectsData? projectsData;
    private ContactData? contactData;
    private bool isLoading = true;

    private int GetTotalSkillsCount()
    {
        return skillsData?.Categories.Sum(c => c.Skills.Count) ?? 0;
    }

    private string GetAchievementIcon(string categoryTitle)
    {
        return categoryTitle.ToLower() switch
        {
            var title when title.Contains("backend") || title.Contains("server") => "bi-server",
            var title when title.Contains("frontend") || title.Contains("client") => "bi-palette-fill",
            var title when title.Contains("database") => "bi-database-fill",
            var title when title.Contains("cloud") || title.Contains("devops") => "bi-cloud-fill",
            var title when title.Contains("security") || title.Contains("identity") => "bi-shield-lock-fill",
            var title when title.Contains("mobile") => "bi-phone-fill",
            var title when title.Contains("framework") => "bi-tools",
            var title when title.Contains("tool") => "bi-tools",
            var title when title.Contains("language") => "bi-code-slash",
            _ => "bi-star-fill"
        };
    }

    private string GetSkillIcon(string skillName)
    {
        var skill = skillName.ToLower();
        return skill switch
        {
            var s when s.Contains("azure") => "bi-microsoft",
            var s when s.Contains("google") || s.Contains("gcp") => "bi-google",
            var s when s.Contains("postgres") => "bi-database-fill-gear",
            var s when s.Contains("sql server") || s.Contains("ms sql") => "bi-database-fill",
            var s when s.Contains(".net") => "bi-box-fill",
            var s when s.Contains("c#") => "bi-code-square",
            var s when s.Contains("javascript") => "bi-filetype-js",
            var s when s.Contains("vue") => "bi-filetype-vue",
            var s when s.Contains("docker") => "bi-box-seam-fill",
            var s when s.Contains("git") => "bi-git",
            var s when s.Contains("blazor") => "bi-lightning-charge-fill",
            var s when s.Contains("flutter") => "bi-phone-fill",
            var s when s.Contains("api") => "bi-plugin",
            var s when s.Contains("security") || s.Contains("oauth") || s.Contains("jwt") || s.Contains("sso") => "bi-shield-lock-fill",
            var s when s.Contains("ci/cd") => "bi-arrow-repeat",
            _ => "bi-star-fill"
        };
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Load all data in parallel for better performance
            var profileTask = DataService.GetProfileDataAsync();
            var skillsTask = DataService.GetSkillsDataAsync();
            var experienceTask = DataService.GetExperienceDataAsync();
            var projectsTask = DataService.GetProjectsDataAsync();
            var contactTask = DataService.GetContactDataAsync();

            await Task.WhenAll(profileTask, skillsTask, experienceTask, projectsTask, contactTask);

            profileData = await profileTask;
            skillsData = await skillsTask;
            experienceData = await experienceTask;
            projectsData = await projectsTask;
            contactData = await contactTask;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}


